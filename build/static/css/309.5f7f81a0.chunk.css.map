.network {
  min-height: 140vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: #0d184e;
  font-family: sans-serif;
}

.network-container {
  width: 90%;
  max-width: 1200px;
  position: relative;
  z-index: 2;
}

/* glow */

.network-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  pointer-events: none;
}

.network-glow1 {
  width: 380px;
  height: 380px;
  background: rgba(63, 68, 218, 0.4);
  top: 20%;
  left: 20%;
}

.network-glow2 {
  width: 300px;
  height: 300px;
  background: rgba(77, 190, 255, 0.475);
  bottom: 20%;
  right: 20%;
}

/* revealed layout */

.network-revealed-state {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 80px;
}

/* LEFT CONTENT */

.network-content-left {
  flex: 1;
}

.network-tag {
  margin-top: 5vh;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #00e0ff;
  font-size: 13px;
  margin-bottom: 10px;
}

.network-content-title {
  font-size: 48px;
  color: white;
  margin-bottom: 20px;
}

.network-content-title span {
  color: #00e0ff;
}

.network-content-desc {
  color: #a0a8c0;
  font-size: 18px;
  line-height: 1.6;
  max-width: 520px;
}

/* FEATURES */

.network-feature-grid {
  margin-top: 40px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18px;
}

.network-feature-card {
  padding: 18px;
  margin: auto;
  width: 360px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: #ffffff;
  transition: all 0.35s ease;
  cursor: pointer;
}

.network-feature-card:hover {
  transform: scale(1.035);
  border: 1px solid rgba(255, 255, 255, 0.689);
  box-shadow:
    0 0 20px rgba(255, 255, 255, 0.119),
    0 0 40px rgba(255, 255, 255, 0.436);
}

.network-feature-card h3 {
  color: rgb(0, 0, 0);
  font-size: 15px;
  margin-bottom: 6px;
}

.network-feature-card p {
  font-size: 13px;
  color: #000000;
}

.network-feature-icon {
  color: #4e66da;
  margin-bottom: 8px;
  transition: transform 0.3s ease;
}

.network-feature-card:hover .network-feature-icon {
  transform: scale(1.15);
}

/* BUTTON */

.network-button-group {
  margin-top: 35px;
  display: flex;
  justify-content: center;
}

.network-primary-btn {
  padding: 16px 30px;
  border: none;
  border-radius: 40px;
  background: linear-gradient(135deg, #3328d6, #0f0963);
  color: white;
  font-weight: 600;
  font-size: 16px;
  cursor: pointer;
  transition: transform 0.25s ease;
}

.network-primary-btn:hover {
  transform: scale(1.05);
}

/* RIGHT IMAGE */

.network-content-right {
  position: relative;
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.network-hero-image-large {
  position: absolute;
  z-index: -199;
  transform: translateX(-250px);
  top: -190px;
  height: 500px;
  width:800px;
  max-width: none;
  object-fit: contain;
  pointer-events: none;
  scale: 1.3;

  filter: drop-shadow(0 0 25px rgba(47, 71, 255, 0.6));

  animation: floatShield 6s ease-in-out infinite;
}

/* floating animation */

@keyframes floatShield {

  0% {
    transform: translateY(0px);
  }

  50% {
    transform: translateY(-15px);
  }

  100% {
    transform: translateY(0px);
  }

}

/* RESPONSIVE */

@media (max-width: 900px) {

  .network-section {
    margin-top: 0;
  }

  .network-revealed-state {
    flex-direction: column;
    text-align: center;
  }

  .network-feature-grid {
    grid-template-columns: 1fr;
  }

  .network-content-title {
    font-size: 40px;
  }

  .network-hero-image-large {
    position: relative;
    width: 320px;
  }

}

@media (max-width: 450px) {

  .network-section {
    min-height: 160vh;
    margin-top: 0;
  }

  .network-tag{
    margin-top: 10vh;
  }

  .network-content-title {
    font-size: 30px;
  }

  .network-content-desc {
    font-size: 15px;
  }

  .network-hero-image-large {
    position: relative;
    top: -100px;
    scale: 2;
    left: -13px
  }

}

/* ---------------------section merge----------------------- */

.network-section {
  min-height:135vh;
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
  overflow:visible;
  font-family:sans-serif;
}

/* outward fade */

.network-section::after{
  content:"";
  position:absolute;
  bottom:-120px;
  left:0;
  width:100%;
  height:120px;

  background:linear-gradient(
    to bottom,
    #540909 0%,
    rgba(84,9,9,0.4) 40%,
    rgba(255,255,255,0.8) 80%,
    white 100%
  );

  pointer-events:none;
}